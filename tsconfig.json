{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "scripts/push-n8n-workflow.ts",
    "scripts/run-test.ts",
    "scripts/run-from-cache.ts",
    "scripts/snapshot-run.ts",
    "trigger.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
