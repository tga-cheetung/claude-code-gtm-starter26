# ─────────────────────────────────────────────────────────────────────────────
# Session 5 — LinkedIn Audience Pipeline (Trigger.dev)
# Copy this file to .env and fill in your keys. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Trigger.dev ──────────────────────────────────────────────────────────────
TRIGGER_SECRET_KEY=
TRIGGER_PROD_SECRET_KEY=

# ── Apify — LinkedIn scraping (https://console.apify.com/account/integrations)
APIFY_API_KEY=

# ── Enrichment waterfall ─────────────────────────────────────────────────────
LEADMAGIC_API_KEY=
AIARK_API_KEY=
EXA_API_KEY=

# ── OpenAI — ICP scoring + copy generation ───────────────────────────────────
OPENAI_API_KEY=

# ── Instantly — campaign push (https://app.instantly.ai/app/settings/integrations)
INSTANTLY_API_KEY=
# Create a paused campaign in Instantly first (with a {{subject}} + {{email_body}}
# sequence template), then paste its UUID here. Leads pushed by this pipeline
# land in this campaign.
INSTANTLY_CAMPAIGN_ID=

# ── RevyOps — canonical lead database (https://app.revyops.com/api/docs) ─────
# Master key required for /contacts-master-list
REVYOPS_MASTER_API_KEY=

# ── Slack — slash command receiver + bot notifications ───────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_NOTIFY_CHANNEL=

# ── n8n — slash command webhook proxy ────────────────────────────────────────
# Cloud subdomain — replace `your-instance` with yours
N8N_API_URL=https://your-instance.app.n8n.cloud/api/v1
N8N_API_KEY=
# Pre-create an httpBearerAuth credential in the n8n UI (token = TRIGGER_SECRET_KEY),
# share it with your project, then paste its ID here.
N8N_TRIGGER_CREDENTIAL_ID=
# Set after first `npm run push-workflow` so subsequent runs update in place.
N8N_WORKFLOW_ID=
