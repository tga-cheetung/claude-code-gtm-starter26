# ─────────────────────────────────────────────────────────────────────────────
# LinkedIn Audience Pipeline — Environment Variables
# Copy this file to .env and fill in your keys.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Apify — LinkedIn scraping (https://console.apify.com/account/integrations)
APIFY_API_KEY=

# Anthropic — AI classification and copy generation (https://console.anthropic.com/keys)
ANTHROPIC_API_KEY=

# OpenAI — fallback model for batch classification (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Enrichment waterfall (Session 3)
LEADMAGIC_API_KEY=
PROSPEO_API_KEY=
PERPLEXITY_API_KEY=

# Smartlead — campaign push via CLI: npm install -g @smartlead/cli (https://app.smartlead.ai/app/settings/api)
SMARTLEAD_API_KEY=

# RevyOps — canonical lead database (https://app.revyops.com/api/docs)
# Standard key: use x-api-key header for /public/contacts and /public/companies endpoints
REVYOPS_API_KEY=
# Master API Key: required for /contacts-master-list and /companies-master-list endpoints
REVYOPS_MASTER_API_KEY=

# Slack — webhook notifications (Session 6)
SLACK_BOT_TOKEN=
